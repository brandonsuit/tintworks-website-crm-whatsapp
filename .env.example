# ── Business profile ─────────────────────────────────────────────────────────
# E.164 without the leading "+". UK example: +44 7735 839280 → 447735839280.
# Used for every wa.me and tel: link.
BUSINESS_PHONE_E164=447735839280
BUSINESS_NAME=Tintworks
BUSINESS_EMAIL=hello@tintworks.example
BUSINESS_ADDRESS="Brown Place, Holbeck, Leeds, LS11, England"

# ── Public site ──────────────────────────────────────────────────────────────
# Swap to the custom domain when DNS cuts over. Drives canonical URLs,
# sitemap entries, OG tags, and JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Analytics (Plausible) ────────────────────────────────────────────────────
# Set to the domain you added in Plausible (e.g. tintworks.co.uk).
# Leave blank locally to skip loading the script.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Google Places (reviews carousel) ────────────────────────────────────────
# Find your Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
#   → Search your business on Google Maps, click Share → embed the map, and copy
#     the "pb=..." segment that contains "ChIJ..." — or use the Place ID Finder tool.
# Create an API key in Google Cloud Console → APIs & Services → Credentials.
#   Enable the "Places API (New)" for the key.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Create the key at https://resend.com/api-keys
RESEND_API_KEY=
# Must be a verified sender on a domain you own in Resend. See README for DNS steps.
EMAIL_FROM="Tintworks <leads@tintworks.example>"
# Where new lead notifications are delivered.
OWNER_NOTIFY_EMAIL=owner@tintworks.example

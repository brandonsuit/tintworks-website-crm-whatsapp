{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null)\" 2>/dev/null && git status --porcelain || true",
            "timeout": 10,
            "statusMessage": "Checking tree state (read-only)"
          }
        ]
      }
    ]
  }
}
